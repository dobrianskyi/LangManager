# Maintainer: PHPManager maintainers

pkgname=phpmanager
pkgver=0.1.0
pkgrel=1
pkgdesc='Qt application for building and managing local PHP CLI versions'
arch=('x86_64')
url='https://local.invalid/PHPManager'
license=('custom')
depends=('qt6-base' 'libarchive')
makedepends=('cmake' 'ninja' 'pkgconf')
source=("${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cmake -S "PHPManager-${pkgver}" -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build
}

package() {
    DESTDIR="${pkgdir}" cmake --install build
}
